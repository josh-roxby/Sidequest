# Supabase — copy to .env.local and fill in.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Preview / design mode: when set to "1" or "true", skips all
# Supabase auth checks and renders pages with a stub demo user.
# Lets the UI be reviewed end-to-end without a Supabase project
# wired up. Leave unset (or "0") for normal auth-enforced mode.
# NEXT_PUBLIC_AUTH_DISABLED=1

# Optional: production OSRM / routing provider override.
# Defaults to the public OSRM demo (rate-limited; not for production).
# OSRM_BASE_URL=https://router.project-osrm.org/route/v1/foot
